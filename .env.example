# Optional: enables cloud AI. Without it, Nexora uses the local AI fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional server port.
PORT=4000

# Local server authentication. Replace both before deployment.
NEXORA_ADMIN_EMAIL=ofir@nexora.ai
NEXORA_ADMIN_PASSWORD=nexora-demo
NEXORA_AUTH_SECRET=replace-with-a-long-random-secret
NEXORA_WORKSPACE_ID=workspace-local

# Comma-separated browser origins allowed to call the API in production.
NEXORA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage provider preparation. The current local runtime uses the file provider.
NEXORA_DATABASE_PROVIDER=file
NEXORA_DATABASE_PATH=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Future production integrations. Keep secrets out of source control.
WHATSAPP_ACCESS_TOKEN=
SMS_PROVIDER_API_KEY=
PAYMENT_PROVIDER_API_KEY=
